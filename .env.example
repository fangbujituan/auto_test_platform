# ============================================================================
# 自动化测试平台环境变量配置示例
# ============================================================================
# 复制此文件为 .env 并填写实际值
# ============================================================================

# ============================================================================
# Local Gateway 配置（局域网部署的本地大模型）- 主要使用这个
# ============================================================================
LOCAL_BASE_URL=http://192.168.1.7:4000/v1
LOCAL_API_KEY=sk-your-super-secret-key-2026

# 默认模型（格式: 网关/模型 或 网关/提供商/模型）
# 可选值:
# - local/llama3.2-1b
# - kiro/claude-sonnet-4.5
# - aiop/azure/gpt-5.4
# - aiclient/claude-kiro-oauth/claude-sonnet-4-6
DEFAULT_MODEL=local/llama3.2-1b

# ============================================================================
# AIOP Gateway 配置（公司统一 AI 网关）
# ============================================================================
AIOP_BASE_URL=https://aiop-gateway.item.com/openai/v1
AIOP_API_KEY=
AIOP_APP_CODE=
AIOP_TENANT_ID=
AIOP_AGENT_CODE=
AIOP_AGENT_NAME=
AIOP_USER_ID=
AIOP_USER_NAME=

# ============================================================================
# Kiro Gateway 配置（备用）
# ============================================================================
KIRO_BASE_URL=http://localhost:9000/v1
KIRO_API_KEY=your-kiro-gateway-secret-key

# ============================================================================
# AIClient2API Gateway 配置（本地多模型网关）
# ============================================================================
AICLIENT_BASE_URL=http://localhost:9000
AICLIENT_API_KEY=sk-test

# ============================================================================
# 其他 API 密钥（可选，需要时配置）
# ============================================================================
# 智谱 AI API 密钥（搜索 MCP）
ZHIPU_API_KEY=
# tvly-dev API 密钥（搜索）
TVLY_API_KEY=

# ============================================================================
# UI 自动化引擎配置
# ============================================================================

# 默认模型名称
UI_ENGINE_MODEL_NAME=gpt-4o-mini

# 默认浏览器类型 (chromium, firefox, webkit)
UI_ENGINE_DEFAULT_BROWSER=chromium

# 是否以无头模式运行浏览器 (true/false)
UI_ENGINE_HEADLESS=true

# 默认超时时间（毫秒）
UI_ENGINE_DEFAULT_TIMEOUT=30000

# Chrome MCP 服务器 URL
UI_ENGINE_CHROME_MCP_URL=http://127.0.0.1:12306/mcp

# Chrome MCP 传输协议
UI_ENGINE_CHROME_MCP_TRANSPORT=http

# 图表 MCP 命令
UI_ENGINE_CHART_MCP_COMMAND=uvx

# Playwright 二进制路径
UI_ENGINE_PLAYWRIGHT_BINARY=npx

# 测试结果目录
UI_ENGINE_RESULTS_DIR=/playwright_results

# HTML报告目录
UI_ENGINE_REPORTS_DIR=/playwright_reports

# Base64图片保存目录
UI_ENGINE_BASE64_IMAGES_DIR=/base64_images

# ============================================================================
# 数据库配置
# ============================================================================
# DATABASE_URL=mysql+pymysql://user:password@localhost/dbname
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

# ============================================================================
# 日志配置
# ============================================================================
# LOG_LEVEL=INFO
# LOG_FILE=/var/log/auto_test_platform.log
# LOG_FORMAT=json

# ============================================================================
# 安全配置
# ============================================================================
# SECRET_KEY=your-secret-key-here
# JWT_SECRET=your-jwt-secret-here
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================================================
# 性能配置
# ============================================================================
# WORKER_COUNT=4
# REQUEST_TIMEOUT=60
# MAX_REQUEST_SIZE=10485760  # 10MB


# ============================================================================
# MySQL 数据库
# ----------------------------------------------------------------------------
# 注意：密码里若含有 $ 等特殊字符，必须用单引号包裹，避免被 dotenv 当作变量插值
# ============================================================================
MYSQL_HOST=mysql-db
MYSQL_PORT=3306
MYSQL_USER=your_user
MYSQL_PASSWORD='your_password'
MYSQL_DATABASE=business

# ============================================================================
# AI 模块加密密钥（Fernet）
# ----------------------------------------------------------------------------
# 用于加解密 ai_provider_configs.api_key_encrypted。
# ⚠️ 一旦生成不要随意更换：换 key 后旧密文全部解不开，需要重新加密入库。
# 生产环境请通过部署系统注入，不要把真实密钥提交到仓库。
# ============================================================================
AI_ENCRYPTION_KEY=your-fernet-key-here

# ============================================================================
# 部署端口配置
# ============================================================================
BACKEND_PORT=12048
FRONTEND_PORT=1801

# ============================================================================
# Flask 应用配置
# ============================================================================
FLASK_ENV=production
SECRET_KEY=your-production-secret-key-here-change-me

# ============================================================================
# MySQL Root 用户密码
# ----------------------------------------------------------------------------
# 注意：这个密码用于 MySQL root 用户，与上面的 MYSQL_PASSWORD 不同
# ============================================================================
MYSQL_ROOT_PASSWORD='your-mysql-root-password-here'