# ============================================================================
# Kiro Gateway 配置
# ============================================================================
# Kiro Gateway API 端点（本地部署 kiro-gateway 后填写）
KIRO_BASE_URL=http://localhost:9000/v1

# Kiro Gateway API 密钥（与 kiro-gateway 的 PROXY_API_KEY 保持一致）
KIRO_API_KEY=your-kiro-gateway-secret-key

# 默认模型
# 可选值：claude-sonnet-4-5, claude-sonnet-4-6, claude-haiku-4-5, 
#         claude-opus-4-5, deepseek-v3.2, qwen3-coder-next, auto
DEFAULT_MODEL=claude-sonnet-4.5

# ============================================================================
# 其他 API 密钥（可选）
# ============================================================================

# 智谱 AI API 密钥（用于搜索 MCP）
ZHIPU_API_KEY=your-zhipu-api-key

# tvly-dev API 密钥（用于 Tavily 搜索）
TVLY_API_KEY=tvly-dev-your-tvly-api-key
