# =============================================================================
# Code Factory - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
APP_ENV=development  # development | testing | production

# -----------------------------------------------------------------------------
# Database (PostgreSQL + PGVector)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=code_factory
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# -----------------------------------------------------------------------------
# Local Model Endpoints (Ollama / vLLM)
# -----------------------------------------------------------------------------
LOCAL_MODEL_ENDPOINT=http://localhost:11434
LOCAL_MODEL_NAME=ollama/qwen2.5:32b

# -----------------------------------------------------------------------------
# Cloud Model API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# -----------------------------------------------------------------------------
# LiteLLM Configuration
# -----------------------------------------------------------------------------
LITELLM_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Embedding Model
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_DIMENSION=1536

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
SIMILARITY_THRESHOLD=0.7
DEFAULT_TOP_K=5
VECTOR_STORE_COLLECTION=knowledge_base

# -----------------------------------------------------------------------------
# Review Gate
# -----------------------------------------------------------------------------
REVIEW_TIMEOUT_SECONDS=3600
REVIEW_WEBHOOK_URL=http://localhost:8080/webhooks/review

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
